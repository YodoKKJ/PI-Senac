generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Serie {
  id     Int     @id @default(autoincrement())
  nome   String  @unique
  turmas Turma[]

  @@map("series")
}

model Turma {
  id        Int    @id @default(autoincrement())
  nome      String
  serieId   Int    @map("serie_id")
  anoLetivo Int    @map("ano_letivo")

  serie                  Serie                  @relation(fields: [serieId], references: [id])
  alunoTurmas            AlunoTurma[]
  professorTurmaMaterias ProfessorTurmaMateria[]
  avaliacoes             Avaliacao[]
  presencas              Presenca[]

  @@map("turmas")
}

model Aluno {
  id             Int       @id @default(autoincrement())
  nome           String
  matricula      String?   @unique
  dataNascimento DateTime? @map("data_nascimento") @db.Date
  nomePai        String?   @map("nome_pai")
  nomeMae        String?   @map("nome_mae")
  telefone       String?
  email          String?

  alunoTurmas AlunoTurma[]
  notas       Nota[]
  presencas   Presenca[]

  @@map("alunos")
}

model Professor {
  id            Int     @id @default(autoincrement())
  nome          String
  email         String?
  telefone      String?
  especialidade String?

  professorTurmaMaterias ProfessorTurmaMateria[]

  @@map("professores")
}

model Materia {
  id   Int    @id @default(autoincrement())
  nome String @unique

  professorTurmaMaterias ProfessorTurmaMateria[]
  avaliacoes             Avaliacao[]
  presencas              Presenca[]

  @@map("materias")
}

model AlunoTurma {
  alunoId Int @map("aluno_id")
  turmaId Int @map("turma_id")

  aluno Aluno @relation(fields: [alunoId], references: [id])
  turma Turma @relation(fields: [turmaId], references: [id])

  @@id([alunoId, turmaId])
  @@map("aluno_turma")
}

model ProfessorTurmaMateria {
  id          Int @id @default(autoincrement())
  professorId Int @map("professor_id")
  turmaId     Int @map("turma_id")
  materiaId   Int @map("materia_id")

  professor Professor @relation(fields: [professorId], references: [id])
  turma     Turma     @relation(fields: [turmaId], references: [id])
  materia   Materia   @relation(fields: [materiaId], references: [id])

  @@unique([professorId, turmaId, materiaId])
  @@map("professor_turma_materia")
}

model Avaliacao {
  id            Int           @id @default(autoincrement())
  turmaId       Int           @map("turma_id")
  materiaId     Int           @map("materia_id")
  tipo          TipoAvaliacao
  descricao     String?
  dataAplicacao DateTime      @map("data_aplicacao") @db.Date
  peso          Decimal       @db.Decimal(5, 2)
  bimestre      Int

  turma   Turma   @relation(fields: [turmaId], references: [id])
  materia Materia @relation(fields: [materiaId], references: [id])
  notas   Nota[]

  @@map("avaliacoes")
}

model Nota {
  id          Int      @id @default(autoincrement())
  avaliacaoId Int      @map("avaliacao_id")
  alunoId     Int      @map("aluno_id")
  valor       Decimal  @db.Decimal(5, 2)
  lancadoEm   DateTime @default(now()) @map("lancado_em")

  avaliacao Avaliacao @relation(fields: [avaliacaoId], references: [id])
  aluno     Aluno     @relation(fields: [alunoId], references: [id])

  @@unique([avaliacaoId, alunoId])
  @@map("notas")
}

model Presenca {
  id        Int      @id @default(autoincrement())
  alunoId   Int      @map("aluno_id")
  turmaId   Int      @map("turma_id")
  materiaId Int      @map("materia_id")
  data      DateTime @db.Date
  presente  Boolean

  aluno   Aluno   @relation(fields: [alunoId], references: [id])
  turma   Turma   @relation(fields: [turmaId], references: [id])
  materia Materia @relation(fields: [materiaId], references: [id])

  @@unique([alunoId, turmaId, materiaId, data])
  @@map("presencas")
}

enum TipoAvaliacao {
  PROVA
  TRABALHO
  SIMULADO
  RECUPERACAO
}
